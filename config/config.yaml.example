# Server settings: binding address and environment data paths
server:
  host: localhost
  port: 38000
  default_environment_base_path: ./environments
  environments_file: ./config/environments.yaml

# Behavior settings: screen behavior tuning (buffer sizes, timeouts, feature flags)
behavior:
  log_tail_lines: 100
  log_buffer_lines: 1000
  file_edit_lock_timeout_sec: 600

# Appearance settings: app branding and sidebar links
appearance:
  app_name: OQTOPUS Manager
  app_icon_path: ./assets/favicon.svg
  favicon_path: ./assets/favicon.svg
  environment_templates:
    - cloud-local
    - backend
  sidebar_links:
    - label: Documentation
      url: https://github.com/snuffkin/oqtopus-manager
    - label: OQTOPUS Cloud
      url: https://your-cloud-url/
    - label: OQTOPUS Admin
      url: https://your-admin-url/
    - label: OQTOPUS Monitoring
      url: https://your-monitoring-url/
    - label: QDash
      url: https://your-qdash-url/

# Debug settings: enables /debug route for inspecting request headers and JWT
# debug: true

# Authentication settings: provider "none" disables auth, "header" reads from proxy headers
auth:
  provider: none
  # provider: header
  # header:
  #   user_header: x-forwarded-email
  #   roles_header: x-forwarded-groups
  #   # allow_raw_roles:        # glob patterns on raw roles_header values, applied
  #   #   - your-app.*          # before role_mappings; omit to allow all
  #   # signout_url: https://your-signout-url/
  #   signature_verification:  # verify JWT from the proxy to prevent header spoofing
  #     enabled: false         # set true to enable; requires pyjwt[crypto]
  #     header: authorization  # request header containing "Bearer <token>"
  #     issuer: https://your-issuer-url/   # e.g. Cognito user pool URL
  #     audience: your-audience            # e.g. Cognito App client ID
  #   # cookie_refresh on the proxy must be shorter than the token expiry
  # role_mappings:             # raw roles_header value → display name; unmapped values pass through as-is
  #   your-app.operator: operator
  #   your-app.admin: admin
